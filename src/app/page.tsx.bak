/** @format */

"use client";

import {
  postApiV1Generate as generate,
  getApiV1Generations,
} from "@/api/generations/generations";
import { GithubComComfyCreatorsCreatorBackendInternalServiceGenerationGenerationResult } from "@/api/models";
import { Button } from "@/components/ui/button";
import { UserButton, SignOutButton } from "@clerk/nextjs";
import { useEffect, useState } from "react";

const Home = () => {
  const [jobs, setJobs] =
    useState<
      GithubComComfyCreatorsCreatorBackendInternalServiceGenerationGenerationResult[]
    >();

  useEffect(() => {
    getApiV1Generations()
      .then((data) => {
        setJobs(data);
      })
      .catch((error) => {
        console.error("Error fetching jobs:", error);
      });
  }, []);

  return (
    <div className="flex flex-col items-center justify-center min-h-screen space-y-4">
      <h1 className="text-4xl font-bold">Welcome to Creator Web</h1>
      <div>
        <Button
          onClick={() =>
            generate({
              generations: [
                {
                  comfy_workflow: [],
                  prompt:
                    "A cat sitting on a windowsill, looking outside at a rainy day, digital art",
                },
              ],
              priority: "urgent",
            })
          }
        >
          Generate Image
        </Button>
      </div>
      <div className="space-y-2">
        {jobs?.length ? (
          jobs?.map(({ generation }) => (
            <div key={generation?.id} className="p-4 border rounded">
              <p>Job ID: {generation?.id}</p>
              <p>Status: {generation?.status}</p>
            </div>
          ))
        ) : (
          <p>No jobs found.</p>
        )}
      </div>
      <p className="text-muted-foreground tracking-tight">
        Authenticated with Clerk
      </p>
      <Button render={<SignOutButton>Sign Out</SignOutButton>}></Button>
      <UserButton showName />
    </div>
  );
};

export default Home;
